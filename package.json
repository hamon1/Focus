{
  "name": "focat",
  "version": "1.0.1",
  "description": "뽀모도 타이머",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.focat.desktop-app",
    "productName": "Focat",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "./renderer/assets/cat.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hamon1/Focus.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/hamon1/Focus/issues"
  },
  "homepage": "https://github.com/hamon1/Focus#readme",
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4"
  },
  "dependencies": {
    "electron-store": "^11.0.2"
  }
}
